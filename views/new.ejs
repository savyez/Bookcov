<%- include('partials/header') %>

<body>
  <div class="container py-4">
    <h1 class="mb-4">Add a New Book</h1>
    <form action="/new" method="POST">
      <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input type="text" id="title" name="book_name" class="form-control" required>
      </div>
      <div class="mb-3">
        <label for="author" class="form-label">Author:</label>
        <select id="author" name="author_name" class="form-select" required>
          <option value="" selected disabled>Select an author</option>
          <% if (authors && authors.length) { %>
            <% authors.forEach((author) => { %>
              <option value="<%= author.author_name %>"><%= author.author_name %></option>
            <% }) %>
          <% } %>
          <option value="__new__">Add new author</option>
        </select>
      </div>
      <div class="mb-3 d-none" id="new-author-wrapper">
        <label for="new_author_name" class="form-label">New Author Name:</label>
        <input type="text" id="new_author_name" name="new_author_name" class="form-control">
      </div>
      <div class="mb-3">
        <label for="date_read" class="form-label">Date Read:</label>
        <input type="date" id="date_read" name="date_read" class="form-control" required>
      </div>
      <div class="mb-3">
        <label for="rating" class="form-label">Rating:</label>
        <input type="number" id="rating" name="rating" min="1" max="10" class="form-control" required>
      </div>
      <div class="mb-3">
        <label for="cover_url" class="form-label">Cover URL:</label>
        <input type="url" id="cover_url" name="cover_url" class="form-control">
      </div>
      <div>
        <label for="review" class="form-label">Review:</label>
        <textarea id="review" name="review" class="form-control" rows="4"></textarea>
      </div>
      <button type="submit" class="btn btn-primary mt-3">Add Book</button>
    </form>
  </div>
  <script>
    const authorSelect = document.getElementById('author');
    const newAuthorWrapper = document.getElementById('new-author-wrapper');
    const newAuthorInput = document.getElementById('new_author_name');

    function toggleNewAuthorInput() {
      const addingNewAuthor = authorSelect.value === '__new__';
      newAuthorWrapper.classList.toggle('d-none', !addingNewAuthor);
      newAuthorInput.required = addingNewAuthor;
      if (!addingNewAuthor) {
        newAuthorInput.value = '';
      }
    }

    authorSelect.addEventListener('change', toggleNewAuthorInput);
    toggleNewAuthorInput();
  </script>

<%- include('partials/footer') %>
