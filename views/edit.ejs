<%- include('partials/header') %>

<body>
  <div class="container py-4">
    <h1 class="mb-4">Edit Book</h1>
    <form action="/internal/dashboard/edit/<%= book.book_id %>" method="POST">
      <div class="mb-3">
        <label for="title" class="form-label">Title:</label>
        <input type="text" id="title" name="book_name" class="form-control" value="<%= book.book_name %>" required>
      </div>
      <div class="mb-3">
        <label for="author" class="form-label">Author:</label>
        <select id="author" name="author_id" class="form-select" required>
          <option value="" disabled>Select an author</option>
          <% if (authors && authors.length) { %>
            <% authors.forEach((author) => { %>
              <option value="<%= author.author_id %>" <%= author.author_id === book.author_id ? 'selected' : '' %>><%= author.author_name %></option>
            <% }) %>
          <% } %>
        </select>
      </div>
      <div class="mb-3">
        <label for="date_read" class="form-label">Date Read:</label>
        <input type="date" id="date_read" name="date_read" class="form-control" value="<%= book.date_read ? book.date_read.toISOString().split('T')[0] : '' %>" required>
      </div>
      <div class="mb-3">
        <label for="rating" class="form-label">Rating:</label>
        <input type="number" id="rating" name="rating" min="1" max="10" class="form-control" value="<%= book.rating %>" required>
      </div>
      <div class="mb-3">
        <label for="shortnote" class="form-label">Shortnote:</label>
        <textarea id="shortnote" name="shortnote" class="form-control" rows="4"><%= book.shortnote %></textarea>
      </div>
      <div class="mb-3">
        <label for="description" class="form-label">Description:</label>
        <textarea id="description" name="description" class="form-control" rows="4"><%= book.description %></textarea>
      </div>
      <div class="d-flex align-items-center gap-2 mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <button type="button" class="btn btn-secondary" onclick="window.location.href = '/internal/dashboard/manage'">Cancel</button>
      </div>
    </form>
  </div>
<%- include('partials/footer') %>
