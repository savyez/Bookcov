<%- include('./partials/header.ejs') %>
<body>
    <div class="container px-4 py-5" id="featured-3"> 
        <h2 class="pb-2 border-bottom">Welcome to the Admin Dashboard</h2>
        <div class="row g-3 py-3 row-cols-1 row-cols-md-2 row-cols-xl-3 mt-2 justify-content-center align-items-stretch"> 
            <div class="feature col d-flex"> 
                <div class="w-100 p-3 border rounded-3 d-flex flex-column"> 
                    <div class="feature-icon mb-3 d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#0d6efd;border-radius:0.375rem;"> 
                        <img class="icon" src="/images/add-book.png" alt="add book icon" style="display:block;width:26px;height:26px;float:none;margin:0;border-radius:0;object-fit:contain;">
                    </div> 
                    <h3 class="fs-2 text-body-emphasis">NEW BOOK</h3> 
                    <p>Add a new book to the library by providing details like title, author, date read, rating, shortnote and review.</p> 
                    <a href="/internal/dashboard/new" class="btn btn-primary mt-auto align-self-start">Add New Book</a> 
                </div>
            </div> 
            <div class="feature col d-flex"> 
                <div class="w-100 p-3 border rounded-3 d-flex flex-column"> 
                    <div class="feature-icon mb-3 d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#0d6efd;border-radius:0.375rem;"> 
                        <img class="icon" src="/images/manage-book.png" alt="manage book icon" style="display:block;width:26px;height:26px;float:none;margin:0;border-radius:0;object-fit:contain;">
                    </div> 
                    <h3 class="fs-2 text-body-emphasis">MANAGE BOOK</h3> 
                    <p>Manage existing books in the library, update their details, and remove books as needed.</p> 
                    <a href="/internal/dashboard/manage" class="btn btn-primary mt-auto align-self-start">Manage Books</a> 
                </div>
            </div> 
            <div class="feature col d-flex"> 
                <div class="w-100 p-3 border rounded-3 d-flex flex-column"> 
                    <div class="feature-icon mb-3 d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;background-color:#0d6efd;border-radius:0.375rem;"> 
                        <img class="icon" src="/images/logout.png" alt="logout icon" style="display:block;width:26px;height:26px;float:none;margin:0;border-radius:0;object-fit:contain;">
                    </div> 
                    <h3 class="fs-2 text-body-emphasis">LOGOUT</h3> 
                    <p>Logout of your admin account and end your session.</p> 
                    <a href="/internal/dashboard/logout" class="btn btn-primary mt-auto align-self-start">Logout</a> 
                </div>
            </div> 
        </div> 
    </div>
</body>

<%- include('./partials/footer.ejs') %>
