<%- include('partials/header.ejs') %>


<body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary rounded" aria-label="Eleventh navbar example"> 
        <div class="container-fluid"> 
            <a class="navbar-brand" href="/">BOOKCOV</a> 
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExample09" aria-controls="navbarsExample09" aria-expanded="false" aria-label="Toggle navigation"> 
                <span class="navbar-toggler-icon"></span> 
            </button> 
            <div class="collapse navbar-collapse" id="navbarsExample09"> 
                <ul class="navbar-nav me-auto mb-2 mb-lg-0"> 
                    <li class="nav-item"> 
                        <a class="nav-link active" aria-current="page" href="#">Home</a> 
                    </li> 
                    <li class="nav-item"> 
                        <a class="nav-link" href="#">Link</a> 
                    </li> 
                    <li class="nav-item dropdown"> 
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false">Sort By</a> 
                        <ul class="dropdown-menu"> 
                            <li><a class="dropdown-item" href="#">Title</a></li> 
                            <li><a class="dropdown-item" href="#">Newest</a></li> 
                            <li><a class="dropdown-item" href="#">Best</a></li> 
                        </ul> 
                    </li> 
                </ul> 
                <form role="search"> 
                    <input class="form-control" type="search" placeholder="Search for books" aria-label="Search"> 
                </form> 
            </div> 
        </div> 
    </nav>
    <div class="container mt-4">
        <% if (locals.books) { %>
            <h1>Books List</h1>
        <% books.forEach(book => { %>
            <div class="book">
                <h2><%= book.book_name %></h2>
                <p>Author: <%= authors.find(a => a.author_id === book.author_id)?.author_name || 'Unknown Author' %></p>
                <p>Date read: <%= book.date_read %></p>
            </div>
            <% }) %>
        <% } else { %>
            <p>No books found.</p>
        <% } %>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>
</body>


<%- include('partials/footer.ejs') %>